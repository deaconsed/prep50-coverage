# Copy this to .env and fill in the real values. .env is gitignored.

# ── Database (point at a Postgres with pgvector 0.8+) ────────────────────
DB_HOST=your-db-host
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=replace-me
DB_NAME=prep50
DB_SSLMODE=require   # use "prefer" for self-hosted, "require" for managed PG

# ── Vertex AI (text-embedding-005) ───────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=vertex_key.json

# ── OpenAI (AI rerank step) ──────────────────────────────────────────────
# Leave blank to disable the AI rerank entirely; cosine-only mode will be used.
OPENAI_API_KEY=

# ── Optional AI rerank tuning ────────────────────────────────────────────
# AI_RERANK_ENABLED=true
# AI_RERANK_MODEL=gpt-4o-mini
# AI_RERANK_TOP_K=20

# ── Optional: which frontend origins the API will accept CORS from ───────
# FRONTEND_ORIGINS=http://localhost:3000,https://yourdomain.com
